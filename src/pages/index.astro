---
import Base from '../layouts/Base.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import CTA from '../components/CTA.astro';

const steps = [
  {
    n: '01',
    title: '15-minute call',
    body: 'We look at your current site together, you tell us what it should be doing for you, and we quote a flat price on the spot.',
  },
  {
    n: '02',
    title: 'Rebuild in 5 business days',
    body: 'You get a mockup in 48 hours and a live site by the end of the week. One round of revisions included.',
  },
  {
    n: '03',
    title: 'We keep it running',
    body: 'Hosting, SSL, backups, security patches, and monthly content updates are bundled into your plan. Nothing extra to manage.',
  },
];

const proof = [
  { stat: '5 days', label: 'Typical turnaround from kickoff to live' },
  { stat: '99.99%', label: 'Hosting uptime backed by enterprise CDN' },
  { stat: '$0', label: 'Surprise fees. Ever. Flat monthly price.' },
];

const faqs = [
  {
    q: 'What if I already have a domain?',
    a: 'We use it. No need to transfer or buy anything new — we just point it at the new site.',
  },
  {
    q: 'Do I own the website?',
    a: 'Yes. Your domain stays in your name. If you ever cancel, we hand off a full export of your content and images.',
  },
  {
    q: 'How are content updates handled?',
    a: 'Email or text us — most updates go live within 24 hours. Standard and Pro plans include monthly content edits.',
  },
  {
    q: 'Is there a contract?',
    a: 'Month-to-month. Cancel anytime. The $299 setup fee covers the rebuild itself.',
  },
];
---
<Base>
  <section class="pt-16 md:pt-24 pb-12">
    <div class="container-tight grid md:grid-cols-2 gap-12 items-center">
      <div>
        <span class="eyebrow">For small businesses with broken or outdated sites</span>
        <h1 class="mt-4 text-4xl md:text-5xl lg:text-6xl font-serif leading-[1.05] text-ink-900">
          Your website is costing you customers.
          <span class="text-accent-700">We rebuild it in 5 days.</span>
        </h1>
        <p class="mt-6 text-lg text-ink-600 max-w-xl">
          Flat $149/month with a one-time $299 setup. Hosting, security, backups, and monthly updates included. No contracts, no surprises.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact" class="btn-primary">Book a 15-min call</a>
          <a href="/work" class="btn-secondary">See our work</a>
        </div>
        <div class="mt-8 flex items-center gap-6 text-sm text-ink-500">
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-accent-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Cancel anytime
          </span>
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-accent-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            14-day money back
          </span>
        </div>
      </div>
      <div>
        <BeforeAfter
          business="Pro Locksmith — Fort Lauderdale, FL"
          vertical="Selected rebuild · Locksmith / 24-hr service"
          beforeYear="dated"
          beforeNote="Cluttered header. Tiny mobile tap targets. Logo + phone competing for attention."
          afterNote="Single-action hero. Tap-to-call front and center. Service areas above the fold."
          beforeMedia={{ type: 'image', src: '/portfolio/locksmith-before.png' }}
          afterMedia={{ type: 'video', src: '/portfolio/locksmith-after.mp4' }}
        />
      </div>
    </div>
  </section>

  <section class="py-16 border-t border-ink-200/70">
    <div class="container-tight">
      <div class="grid sm:grid-cols-3 gap-8">
        {proof.map((p) => (
          <div>
            <div class="text-3xl font-serif text-ink-900">{p.stat}</div>
            <div class="mt-1 text-sm text-ink-500">{p.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-white border-y border-ink-200/70">
    <div class="container-tight">
      <div class="max-w-2xl">
        <span class="eyebrow">How it works</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-serif">From broken to better in one week.</h2>
        <p class="mt-4 text-ink-600">No agency runaround. No mystery invoices. One person on your account from call to launch.</p>
      </div>
      <div class="mt-12 grid md:grid-cols-3 gap-8">
        {steps.map((s) => (
          <div class="relative rounded-xl border border-ink-200 bg-ink-50/50 p-6">
            <div class="text-xs font-medium text-accent-700">{s.n}</div>
            <h3 class="mt-2 text-xl font-serif text-ink-900">{s.title}</h3>
            <p class="mt-3 text-sm text-ink-600 leading-relaxed">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container-tight">
      <div class="flex items-end justify-between flex-wrap gap-4 mb-10">
        <div>
          <span class="eyebrow">Recent client launches</span>
          <h2 class="mt-3 text-3xl md:text-4xl font-serif">What the finished sites look like.</h2>
        </div>
        <a href="/work" class="text-sm text-accent-700 hover:text-accent-800">View all rebuilds &rarr;</a>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <article class="rounded-xl border border-ink-200 bg-white overflow-hidden shadow-sm">
          <div class="aspect-[16/9] bg-ink-100 relative overflow-hidden">
            <img
              src="/portfolio/insulation-after.png"
              alt="Insulation Co. — finished website"
              loading="lazy"
              class="absolute inset-0 h-full w-full object-cover object-top"
            />
          </div>
          <div class="px-5 py-4 border-t border-ink-200 flex items-center justify-between">
            <div>
              <div class="text-sm font-medium text-ink-900">Insulation Co.</div>
              <div class="text-xs text-ink-500">Live · Home services / South Florida</div>
            </div>
            <span class="text-[11px] uppercase tracking-wider text-accent-700">Standard</span>
          </div>
        </article>
        <article class="rounded-xl border border-ink-200 bg-white overflow-hidden shadow-sm">
          <div class="aspect-[16/9] bg-ink-100 relative overflow-hidden">
            <img
              src="/portfolio/directory-after.png"
              alt="Gold Touch List — finished website"
              loading="lazy"
              class="absolute inset-0 h-full w-full object-cover object-top"
            />
          </div>
          <div class="px-5 py-4 border-t border-ink-200 flex items-center justify-between">
            <div>
              <div class="text-sm font-medium text-ink-900">Gold Touch List</div>
              <div class="text-xs text-ink-500">Live · Directory / Nationwide</div>
            </div>
            <span class="text-[11px] uppercase tracking-wider text-accent-700">Pro</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white border-y border-ink-200/70">
    <div class="container-tight">
      <div class="max-w-2xl mb-10">
        <span class="eyebrow">Questions we get on every first call</span>
        <h2 class="mt-3 text-3xl md:text-4xl font-serif">The honest answers.</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-x-12 gap-y-8">
        {faqs.map((f) => (
          <div>
            <h3 class="text-lg font-serif text-ink-900">{f.q}</h3>
            <p class="mt-2 text-sm text-ink-600 leading-relaxed">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Base>
