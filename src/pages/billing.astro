---
import Base from '../layouts/Base.astro';
import { SITE } from '../config/site';

const portalConfigured = Boolean(SITE.stripePortal);
---
<Base title={`Manage billing — ${SITE.brand}`} description="Existing clients: update your payment method, view invoices, or cancel your subscription.">
  <section class="pt-16 pb-20">
    <div class="container-prose">
      <span class="eyebrow">Client billing</span>
      <h1 class="mt-4 text-4xl md:text-5xl font-serif leading-tight text-ink-900">
        Manage your subscription.
      </h1>
      <p class="mt-5 text-ink-600 text-lg">
        Update your card, download invoices, change plans, or cancel — anytime, no email required.
      </p>

      {portalConfigured ? (
        <div class="mt-10 rounded-2xl border border-ink-200 bg-white p-7 shadow-sm">
          <h2 class="text-xl font-serif text-ink-900">Open the secure billing portal</h2>
          <p class="mt-2 text-sm text-ink-600">
            We use Stripe — the same billing system Amazon, Shopify, and Lyft use. Your card details never touch our servers.
          </p>
          <a
            href={SITE.stripePortal!}
            class="btn-primary mt-6 w-full sm:w-auto"
            target="_blank"
            rel="noopener"
          >
            Open billing portal →
          </a>
          <p class="mt-4 text-xs text-ink-500">
            You'll be asked for the email you used when you signed up. Stripe sends you a one-time secure link — no password needed.
          </p>
        </div>
      ) : (
        <div class="mt-10 rounded-2xl border border-amber-200 bg-amber-50 p-7">
          <h2 class="text-xl font-serif text-ink-900">Billing portal coming soon</h2>
          <p class="mt-3 text-sm text-ink-700">
            We're finalizing our self-serve billing portal. In the meantime, email
            <a href={`mailto:${SITE.email}`} class="text-accent-700 hover:text-accent-800 font-medium"> {SITE.email}</a> with any of the following:
          </p>
          <ul class="mt-4 space-y-2 text-sm text-ink-700">
            <li class="flex items-start gap-2"><span class="text-accent-700">•</span> Update your card on file</li>
            <li class="flex items-start gap-2"><span class="text-accent-700">•</span> Request an invoice or receipt</li>
            <li class="flex items-start gap-2"><span class="text-accent-700">•</span> Change your plan (Starter ↔ Standard ↔ Pro)</li>
            <li class="flex items-start gap-2"><span class="text-accent-700">•</span> Pause or cancel your subscription</li>
          </ul>
          <p class="mt-4 text-xs text-ink-500">
            We respond within one business day. Cancellations are processed same-day with no questions asked.
          </p>
        </div>
      )}

      <div class="mt-16">
        <h2 class="text-2xl font-serif text-ink-900">What you can do in the portal</h2>
        <div class="mt-6 grid sm:grid-cols-2 gap-x-10 gap-y-6">
          <div>
            <h3 class="font-medium text-ink-900">Update payment method</h3>
            <p class="mt-1 text-sm text-ink-600">Swap your card without contacting us. The new card is charged on the next renewal.</p>
          </div>
          <div>
            <h3 class="font-medium text-ink-900">Download invoices</h3>
            <p class="mt-1 text-sm text-ink-600">PDF receipts for every charge. Great for end-of-year bookkeeping.</p>
          </div>
          <div>
            <h3 class="font-medium text-ink-900">Switch plans</h3>
            <p class="mt-1 text-sm text-ink-600">Upgrade or downgrade between Starter, Standard, and Pro. Prorated automatically.</p>
          </div>
          <div>
            <h3 class="font-medium text-ink-900">Cancel anytime</h3>
            <p class="mt-1 text-sm text-ink-600">No cancellation fees, no exit interviews, no hold music. One click and you're done.</p>
          </div>
        </div>
      </div>

      <div class="mt-16 rounded-xl border border-ink-200 bg-ink-50/60 p-6">
        <h3 class="font-serif text-lg text-ink-900">If you cancel, what happens to your site?</h3>
        <p class="mt-2 text-sm text-ink-700 leading-relaxed">
          You always own your domain — it's in your name from day one, and it stays with you. When you cancel, we send you a full export of your site (HTML, images, content) within 48 hours and help you point your domain at the next host of your choosing. No hostage situations.
        </p>
      </div>

      <p class="mt-12 text-sm text-ink-500">
        Questions? Email <a href={`mailto:${SITE.email}`} class="text-accent-700 hover:text-accent-800">{SITE.email}</a> or call <a href={SITE.phoneHref} class="text-accent-700 hover:text-accent-800">{SITE.phone}</a>.
      </p>
    </div>
  </section>
</Base>
