---
interface Props {
  business: string;
  vertical: string;
  beforeNote?: string;
  afterNote?: string;
  beforeYear?: string;
  afterHero?: string;
  ctaLabel?: string;
}
const {
  business,
  vertical,
  beforeNote = 'No mobile layout. Broken links. Last updated 2014.',
  afterNote = 'Mobile-first. Fast. Booking form wired to email + SMS.',
  beforeYear = '2014',
  afterHero = 'Trusted by 1,200+ local customers.',
  ctaLabel = 'Book now',
} = Astro.props;
---
<article class="rounded-xl border border-ink-200 bg-white overflow-hidden shadow-sm">
  <div class="grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-ink-200">
    {/* BEFORE — busy, dated, broken */}
    <div class="p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[11px] uppercase tracking-wider text-ink-400 font-medium">Before</span>
        <span class="text-[11px] text-rose-700 bg-rose-50 px-2 py-0.5 rounded">Broken · {beforeYear}</span>
      </div>
      <div class="aspect-[4/3] rounded-md bg-[#e8e4d9] border border-ink-300 relative overflow-hidden shadow-inner">
        {/* fake browser chrome */}
        <div class="absolute top-0 inset-x-0 h-5 bg-ink-200 border-b border-ink-300 flex items-center px-2 gap-1">
          <span class="h-1.5 w-1.5 rounded-full bg-rose-400"></span>
          <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
          <div class="ml-2 h-2 w-24 bg-white rounded-sm border border-ink-300"></div>
          <span class="ml-auto text-[7px] text-rose-700 font-bold">⚠ Not Secure</span>
        </div>
        {/* page body */}
        <div class="absolute inset-0 top-5 p-2 flex flex-col gap-1">
          {/* header */}
          <div class="bg-[#003366] text-white px-2 py-1 flex items-center justify-between">
            <span class="text-[8px] font-bold tracking-wide">{business.toUpperCase()}</span>
            <div class="flex gap-1 text-[6px]">
              <span>HOME</span><span>SVCS</span><span>CONTACT</span>
            </div>
          </div>
          {/* hero — broken image */}
          <div class="bg-white border border-ink-300 h-12 flex items-center justify-center">
            <div class="text-[6px] text-rose-600 flex flex-col items-center">
              <span class="text-[10px]">✕</span>
              <span>image not found</span>
            </div>
          </div>
          {/* body text */}
          <div class="bg-white p-1.5 flex flex-col gap-0.5">
            <div class="h-1 w-3/4 bg-ink-700"></div>
            <div class="h-1 w-full bg-ink-400"></div>
            <div class="h-1 w-5/6 bg-ink-400"></div>
            <div class="h-1 w-2/3 bg-ink-400"></div>
            <span class="text-[6px] text-blue-700 underline mt-0.5">Click here for our menu.pdf</span>
          </div>
          {/* visitor counter — peak 2008 */}
          <div class="mt-auto flex items-center justify-between text-[6px] text-ink-500">
            <span>Visitors: 0042913</span>
            <span class="bg-ink-200 px-1">Best viewed in IE</span>
          </div>
        </div>
      </div>
      <p class="mt-3 text-xs text-ink-500 leading-relaxed">{beforeNote}</p>
    </div>

    {/* AFTER — clean, modern, mobile-aware */}
    <div class="p-5 bg-ink-50/50">
      <div class="flex items-center justify-between mb-3">
        <span class="text-[11px] uppercase tracking-wider text-accent-700 font-medium">After</span>
        <span class="text-[11px] text-accent-700 bg-accent-50 px-2 py-0.5 rounded">Live · {new Date().getFullYear()}</span>
      </div>
      <div class="aspect-[4/3] rounded-md bg-white border border-ink-200 relative overflow-hidden shadow-sm">
        {/* fake browser chrome */}
        <div class="absolute top-0 inset-x-0 h-5 bg-ink-100 border-b border-ink-200 flex items-center px-2 gap-1">
          <span class="h-1.5 w-1.5 rounded-full bg-rose-300"></span>
          <span class="h-1.5 w-1.5 rounded-full bg-amber-300"></span>
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-300"></span>
          <div class="ml-2 h-2 w-28 bg-white rounded-sm border border-ink-200 flex items-center px-1">
            <span class="text-[6px] text-accent-700">🔒</span>
          </div>
          <span class="ml-auto text-[7px] text-emerald-700">A+ · Fast</span>
        </div>
        {/* page body */}
        <div class="absolute inset-0 top-5 flex flex-col">
          {/* nav */}
          <div class="px-2 py-1.5 flex items-center justify-between border-b border-ink-100">
            <div class="flex items-center gap-1">
              <span class="h-2 w-2 rounded-sm bg-accent-700"></span>
              <span class="text-[7px] font-serif text-ink-900">{business}</span>
            </div>
            <div class="flex items-center gap-1.5 text-[6px] text-ink-500">
              <span>Services</span><span>About</span><span>Contact</span>
              <span class="bg-accent-700 text-white px-1.5 py-0.5 rounded-sm">{ctaLabel}</span>
            </div>
          </div>
          {/* hero */}
          <div class="px-2 py-2 bg-gradient-to-br from-accent-50 via-white to-white flex-1 flex flex-col justify-center">
            <span class="text-[6px] uppercase tracking-wider text-accent-700">{vertical.split('·').pop()?.trim() ?? vertical}</span>
            <div class="mt-1 text-[10px] font-serif text-ink-900 leading-tight">{afterHero}</div>
            <div class="mt-1.5 flex gap-1">
              <span class="bg-accent-700 text-white text-[6px] px-1.5 py-0.5 rounded-sm">{ctaLabel}</span>
              <span class="border border-ink-300 text-[6px] px-1.5 py-0.5 rounded-sm text-ink-700">Learn more</span>
            </div>
          </div>
          {/* trust strip */}
          <div class="px-2 py-1 border-t border-ink-100 flex items-center justify-between text-[6px]">
            <span class="flex items-center gap-0.5 text-amber-500">★★★★★ <span class="text-ink-500 ml-0.5">4.9 · Google</span></span>
            <span class="text-ink-500">📞 Tap to call</span>
          </div>
        </div>
      </div>
      <p class="mt-3 text-xs text-ink-600 leading-relaxed">{afterNote}</p>
    </div>
  </div>
  <div class="px-5 py-3 border-t border-ink-200 bg-white flex items-center justify-between">
    <div>
      <div class="text-sm font-medium text-ink-900">{business}</div>
      <div class="text-xs text-ink-500">{vertical}</div>
    </div>
    <span class="text-[11px] uppercase tracking-wider text-ink-400">Concept rebuild</span>
  </div>
</article>
